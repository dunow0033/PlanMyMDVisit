@model planMyMDVisit.Models.ViewModels.AdminCreateUserViewModel

@{
    ViewData["Name"] = ViewData["Name"];
}

<form method="post">
	<div class="mb-3">
		<label class="form-label">First Name</label>
		<input type="text" id="firstname" class="form-control" asp-for="Firstname" registered />
		<span class="text-danger" asp-validation-for="Firstname"></span>
	</div>

	<div class="mb-3">
		<label class="form-label">Last Name</label>
		<input type="text" id="lastname" class="form-control" asp-for="Lastname" required />
		<span class="text-danger" asp-validation-for="Lastname"></span>
	</div>

	<div class="mb-3">
		<label class="form-label">Username</label>
		<input type="text" id="username" class="form-control" asp-for="UserName" required />
		<span class="text-danger" asp-validation-for="UserName"></span>
	</div>

	<br />
	<br />

	<label for="AdminOrRegularUser">Admin</label>
	<input class="form-check-input" type="radio" asp-for="AdminOrRegularUser" name="AdminOrRegularUser" value="Admin" />

	<div id="regUser" style="display: block;">
		<label for="AdminOrRegularUser">Regular User</label>
		<input class="form-check-input" type="radio" asp-for="AdminOrRegularUser" name="AdminOrRegularUser" value="RegularUser" />
	</div>

	<br />
	<br />

	<label for="DoctorOrPatient">Doctor</label>
	<input class="form-check-input" type="radio" asp-for="DoctorOrPatient" name="DoctorOrPatient" value="Doctor" />

	<div id="patient" style="display: block;">
		<label for="DoctorOrPatient">Patient</label>
		<input class="form-check-input" type="radio" asp-for="DoctorOrPatient" name="DoctorOrPatient" value="Patient" />
	</div>

	<br />
	<br />

	<div id="extraPatientFields" style="display: none;">
		<div class="mb-3">
			@Html.LabelFor(m => m.Patient.medicalRecord, "Medical Record")
			@Html.TextBoxFor(m => m.Patient.medicalRecord, new { @class = "form-control" })
		</div>

		<div class="mb-3">
			@Html.LabelFor(m => m.Patient.testResults, "Test Results")
			@Html.TextBoxFor(m => m.Patient.testResults, new { @class = "form-control" })
		</div>

		<div class="mb-3">
			@Html.LabelFor(m => m.Patient.medications, "Medications")
			@Html.TextBoxFor(m => m.Patient.medications, new { @class = "form-control" })
		</div>
	</div>

	<div class="mb-3">
		<label class="form-label">Email</label>
		<input type="email" id="email" class="form-control" asp-for="Email" required />
		<span class="text-danger" asp-validation-for="Email"></span>
	</div>

	<div class="mb-3">
		<label class="form-label">Password</label>
		<input type="password" id="password" class="form-control" asp-for="Password" required minlength="6" />
		<span class="text-danger" asp-validation-for="Password"></span>
	</div>

	<div class="mb-3">
		<button type="submit" class="btn btn-dark">Register</button>
	</div>
</form>


<script>
	document.addEventListener("DOMContentLoaded", function () {
		const adminRadio = document.querySelector('input[name="AdminOrRegularUser"][value="Admin"]');
		const regUserRadio = document.querySelector('input[name="AdminOrRegularUser"][value="RegularUser"]');
		const patientDiv = document.getElementById("patient");
		const patientRadio = document.querySelector('input[name="DoctorOrPatient"][value="Patient"]');
		const doctorRadio = document.querySelector('input[name="DoctorOrPatient"][value="Doctor"]');
		const extraPatientFields = document.getElementById("extraPatientFields");

		function updateFormVisibility() {
			if(adminRadio.checked) {
				patientDiv.style.display = "none";
				extraPatientFields.style.display = "none";
			} else if (regUserRadio.checked) {
				patientDiv.style.display = "block";

				if(patientRadio.checked) {
					extraPatientFields.style.display = "block";
				} else {
					extraPatientFields.style.display = "none";
				}
			}
		}

		function togglePatientOff() {
			if(adminRadio.checked) {
				patient.style.display = "none";
			} else {
				patient.style.display = "block";
			}
		}

		function togglePatientOn() {
			if(regUserRadio.checked) {
				patient.style.display = "block";
			} else {
				patient.style.display = "none";
			}
		}

		function toggleExtraPatientFieldsOn() {
			if(patientRadio.checked) {
				extraPatientFields.style.display = "block";
			} else {
				extraPatientFields.style.display = "none";
			}
		}

		function toggleExtraPatientFieldsOff() {
			if(patientRadio.checked) {
				extraPatientFields.style.display = "none";
			} else {
				extraPatientFields.style.display = "block";
			}
		}

		function both(){
			toggleExtraPatientFieldsOff();
			togglePatientOff();
		}

		patientRadio.addEventListener("change", updateFormVisibility);
		doctorRadio.addEventListener("change", updateFormVisibility);
		adminRadio.addEventListener("change", updateFormVisibility);
		regUserRadio.addEventListener("change", updateFormVisibility);

		updateFormVisibility();

		//toggleExtraPatientFields();
	})
</script>
