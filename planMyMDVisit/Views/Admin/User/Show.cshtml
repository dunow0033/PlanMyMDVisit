@model planMyMDVisit.Models.ViewModels.DoctorPatientUserViewModel
@using planMyMDVisit.Utilities

@{
    var userId = Model.User.Id.ToString();
}

<h4>User Profile</h4>
<b>Fullname: </b><i>@Model.User.FullName()</i>
<br>
<b>Username: </b><i>@Model.User.UserName</i>
<br>
<b>Email: </b><i>@Model.User.Email</i>
<br>
<b>Admin: </b><i>@(Model.User.Admin ? "Yes" : "No")</i>
<br>
<br>
<a class="btn btn-primary" asp-area="" asp-controller="Admin" asp-action="EditUser" asp-route-id="@Model.User.Id">Edit Profile</a>
<br>
<br>
<button type="button" class="btn btn-danger delete-item"
        data-toggle="modal"
        data-target="#deleteConfirmationModal"
        data-id="@Model.User.Id">
    Delete User
</button>

<div class="modal fade" id="deleteConfirmationModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Deletion</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this user? This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteButton">Delete</button>
            </div>
        </div>
    </div>
</div>

@if (Model.Patient != null)
{
    <br />
    <br />
    <h4>Patient Information</h4>
    <b>Medical Records: </b>

    <i>Information about patient's conditions and recommended treatment plan</i>
    <br>
    <b>Test Results: </b>

    <i>Test Results</i>
    <br>
    <br>
    <b>Medications: </b>

    <i>Medications</i>
    <br>
    <br>
    <a asp-controller="Admin"
       asp-action="EditPatientInfo"
       asp-route-patientId="@Model.Patient.Id"
       class="btn btn-primary">Edit Patient Information</a>

    <div class="row">
        <div class="col s12 m4 l4">
            <h5>Care Teams</h5>

            @foreach (var hct in Helpers.TwoLatestCareTeams(Model.Patient))
            {
                <div class="card blue lighten-5">
                    <div class="card-content black-text">
                        <span class="card-title truncate">@hct.Doctor.Specialty</span>
                    </div>
                    <div class="card-action">
                        @hct.Doctor.User.FullName()
                    </div>
                    <div class="card-action" align="center">
                        <a asp-controller="HealthCareTeams"
                           asp-action="Edit"
                           asp-route-id="@hct.Id"
                           class="btn btn-sm btn-primary">Edit Care Team</a>
                        <br><br>
                        <a asp-controller="HealthCareTeams"
                           asp-action="Delete"
                           asp-route-id="@hct.Id"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Are you sure you want to remove this care team?')">Delete Care Team</a>
                    </div>
                </div>
            }
        </div>
    </div>
}
else if (Model.Doctor != null)
{
    <br />
    <br />
    <h4>Doctor Information</h4>
    <b>Specialty: </b>

    <i>@Model.Doctor.Specialty</i>
    <br>
    <b>Address: </b>

    <i>Address</i>
    <br>
    <br>
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.bundle.min.js"></script>

<script>
    $(document).ready(function () {
        var itemIdToDelete;

        $('.delete-item').on('click', function () {
            itemIdToDelete = $(this).data('id');
            $('#deleteConfirmationModal').modal('show');
        });

        $('#confirmDeleteButton').on('click', function () {
            $.ajax({
                url: '/Admin/DeletePatient',
                type: 'POST',
                data: { id: itemIdToDelete },
                success: function (result) {
                    $('#deleteConfirmationModal').modal('hide');
                    location.reload();
                },
                error: function (xhr, status, error) {
                    console.error("Error deleting item:", error);
                }
            });
        });
    });
</script>
