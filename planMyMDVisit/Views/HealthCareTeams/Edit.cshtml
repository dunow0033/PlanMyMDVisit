@model planMyMDVisit.Models.ViewModels.CreateApptRequest

<h4>Edit Care Team</h4>

<form asp-controller="HealthCareTeams" asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <div class="mb-3">
        <label class="form-label">Specialty</label>
        <select asp-for="Specialty" asp-items="Model.SpecialtySelectList" class="form-control">
            <option selected disabled>-- SELECT SPECIALTY --</option>
        </select>
        <span asp-validation-for="Specialty" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Appointment Date</label>
        <input type="datetime-local" asp-for="Appointment" class="form-control" />
        <span asp-validation-for="Appointment" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Show" asp-controller="Patients" class="btn btn-secondary">Cancel</a>
</form>
