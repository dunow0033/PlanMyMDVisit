@model planMyMDVisit.Models.Domain.HealthCareTeam

<h4>Delete Care Team</h4>

<div class="card blue lighten-5" style="max-width: 400px;">
    <div class="card-content black-text">
        <span class="card-title">@Model.Specialty</span>
        <p>Doctor: @Model.Doctor.User.FullName()</p>
        <p>Appointment: @Model.Appointment.ToString("MMM dd, yyyy h:mm tt")</p>
    </div>
</div>

<br />
<p class="text-danger">Are you sure you want to delete this care team?</p>

<form asp-controller="HealthCareTeams" asp-action="Delete" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Show" asp-controller="Patients" class="btn btn-secondary">Cancel</a>
</form>